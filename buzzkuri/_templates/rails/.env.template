# Railsプロジェクト用プレースホルダー定義
# このファイルをコピーして .env.local を作成し、値を埋めてから sync スクリプトを実行すること
# .env.local は gitignore 対象（秘密情報を含む場合も安全）

RUBY_VERSION=3.3.6
RAILS_VERSION=6.1.7.2
DB_ENGINE=MySQL 8.4
DB_SCHEMA_TOOL=Ridgepole
JOB_FRAMEWORK=Sidekiq 5.x
API_DOC_TOOL=rswag
UPLOAD_TOOL=CarrierWave + S3
MAILER_TOOL=SendGrid
PROJECT_NAMESPACE=api/v1
